#!/usr/bin/env python3
"""pulpie-browser: Render JS page → Pulpie → clean Markdown → stdout.

Auto-detects CAMOFOX_URL — routes through Camoufox anti-detection Firefox if set,
falling back to Playwright Chromium on any failure.

Usage:  pulpie-browser <url>   |   echo "<url>" | pulpie-browser
"""

import os, sys, hashlib, logging, time, uuid, subprocess
from urllib.parse import urlparse

logging.getLogger("pulpie").setLevel(logging.WARNING)
logging.getLogger("transformers").setLevel(logging.WARNING)
logging.getLogger("playwright").setLevel(logging.WARNING)

CACHE_DIR = os.path.expanduser("~/.hermes/cache/web")
CHROME = os.path.expanduser("~/.cache/ms-playwright/chromium-1228/chrome-linux64/chrome")
CAMOFOX_SCRIPT = os.path.expanduser("~/.hermes/scripts/camofox-manage.sh")


def _cache_path(url):
    domain = urlparse(url).netloc
    h = hashlib.sha256(url.encode()).hexdigest()[:12]
    return os.path.join(CACHE_DIR, f"{domain}-{h}.md")


def _extract(html, url):
    from pulpie import Extractor

    markdown = Extractor(max_tokens=2048, max_batch_tokens=4096).extract(html).markdown or ""
    raw_len, clean_len = len(html), len(markdown)
    if raw_len:
        saved = round((1 - clean_len / raw_len) * 100, 1)
        markdown += f"\n\n---\n*Pulpie extraction: {raw_len:,} → {clean_len:,} chars ({saved}% saved)*\n"

    os.makedirs(CACHE_DIR, exist_ok=True)
    with open(_cache_path(url), "w") as f:
        f.write(markdown)
    print(markdown)


def _camoufox_healthy(base, timeout):
    """Poll /health until 200 or timeout."""
    import requests
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            if requests.get(f"{base}/health", timeout=5).status_code == 200:
                return True
        except requests.RequestException:
            pass
        time.sleep(1)
    return False


def _camoufox_start():
    """Start Camoufox server. Returns True/False."""
    try:
        result = subprocess.run(
            ["bash", CAMOFOX_SCRIPT, "start"],
            capture_output=True, text=True, timeout=30,
        )
        return result.returncode == 0
    except Exception:
        return False


def _camoufox_extract(url, base):
    """Extract page via Camoufox REST API. Returns True on success."""
    import requests

    user_id = f"pulpie_{uuid.uuid4().hex[:10]}"
    session_key = f"pulpie_{uuid.uuid4().hex[:8]}"

    try:
        # Create tab + navigate
        resp = requests.post(
            f"{base}/tabs",
            json={"userId": user_id, "listItemId": session_key, "url": url},
            timeout=60,
        )
        resp.raise_for_status()
        tab_id = resp.json().get("tabId")
        if not tab_id:
            return False

        time.sleep(2)  # let JS render

        # Evaluate JS → get HTML
        resp = requests.post(
            f"{base}/tabs/{tab_id}/evaluate",
            json={"expression": "document.documentElement.outerHTML", "userId": user_id},
            timeout=30,
        )
        resp.raise_for_status()
        html = resp.json().get("result", "")

        if not html or not isinstance(html, str) or len(html) < 50:
            return False

    except requests.RequestException:
        return False
    finally:
        try:
            requests.delete(f"{base}/sessions/{user_id}", timeout=10)
        except Exception:
            pass

    _extract(html, url)
    return True


def _playwright_extract(url):
    """Fallback: Playwright Chromium → Pulpie."""
    from playwright.sync_api import sync_playwright

    with sync_playwright() as p:
        browser = p.chromium.launch(executable_path=CHROME, headless=True)
        context = browser.new_context(
            user_agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
                       "(KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36",
            viewport={"width": 1920, "height": 1080},
        )
        page = context.new_page()
        page.goto(url, wait_until="domcontentloaded", timeout=60000)
        page.wait_for_timeout(3000)
        html = page.content()
        browser.close()

    _extract(html, url)


def main():
    url = (sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read().strip())
    if not url:
        print("Usage: pulpie-browser <url>", file=sys.stderr)
        sys.exit(1)

    base = os.getenv("CAMOFOX_URL", "").rstrip("/")
    if base:
        if not _camoufox_healthy(base, timeout=3):
            if not _camoufox_start() or not _camoufox_healthy(base, timeout=20):
                base = ""
        if base and _camoufox_extract(url, base):
            return

    _playwright_extract(url)


if __name__ == "__main__":
    main()
